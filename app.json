{
  "expo": {
    "name": "TheTotal",
    "slug": "thetotal",
    "scheme": "thetotal",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "platforms": ["ios", "android"],
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": false },
    "android": { "adaptiveIcon": { "foregroundImage": "./assets/adaptive-icon.png", "backgroundColor": "#0d0d1a" } },
    "plugins": ["expo-router"],
    "experiments": { "typedRoutes": true }
  }
}
